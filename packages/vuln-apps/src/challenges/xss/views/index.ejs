<h2>Cross-Site Scripting (XSS) <span class="badge easy">Challenge</span></h2>

<div class="card">
  <p style="margin-bottom: 1rem; color: #94a3b8;">
    This forum allows users to post messages. Can you inject JavaScript that executes in other users' browsers?
  </p>

  <h3 style="margin-bottom: 0.75rem;">Search Posts</h3>
  <form method="GET" action="/challenges/xss/search">
    <input type="text" name="q" placeholder="Search posts..." value="<%= typeof query !== 'undefined' ? query : '' %>">
    <input type="submit" value="Search">
  </form>
</div>

<div class="card">
  <h3 style="margin-bottom: 0.75rem;">Post a Message</h3>
  <form method="POST" action="/challenges/xss/post">
    <input type="text" name="author" placeholder="Your name" required>
    <textarea name="content" rows="3" placeholder="Write your message..." required></textarea>
    <input type="submit" value="Post Message">
  </form>
</div>

<div class="card">
  <h3 style="margin-bottom: 0.75rem;">Forum Posts</h3>
  <% if (posts && posts.length > 0) { %>
    <% posts.forEach(function(post) { %>
      <div class="post">
        <span class="author"><%= post.author %></span>
        <span class="date"> - <%= post.created_at %></span>
        <p style="margin-top: 0.5rem;"><%- post.content %></p>
      </div>
    <% }); %>
  <% } else { %>
    <p style="color: #64748b;">No posts yet.</p>
  <% } %>
</div>
